---
layout: layouts/base.njk
pagination:
  data: products
  size: 1
  alias: product
  addAllPagesToCollections: true
permalink: "/product/{{ product.slug }}/"
nav: products
sitemapPriority: "0.8"
eleventyComputed:
  title: "{{ product.title }}"
  description: "{{ product.description }}"
  ogImage: "{{ product.ogImage }}"
  preloadImage: "{{ product.images[0].src }}"
---
{% from "partials/related-card.njk" import relatedCard %}
    <script type="application/ld+json">{{ product | productJsonLd | safe }}</script>
    <script type="application/ld+json">{{ product | breadcrumbJsonLd | safe }}</script>
    <!-- PRODUCT DETAIL -->
    <section class="section pdp" aria-labelledby="pdp-heading">
      <div class="container">
        <p class="pdp__breadcrumb">
          <a href="/">Home</a>
          <span class="pdp__breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
          <a href="/products/">Products</a>
          <span class="pdp__breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
          <a href="/premium-cigars/">Premium Cigar Bundles</a>
          <span class="pdp__breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
          <span class="pdp__breadcrumb-current">{{ product.name }}</span>
        </p>
        <div class="pdp__grid">
          <div class="pdp__media">
{% if product.images.length > 1 %}
            <div class="pdp-slider" aria-roledescription="carousel" aria-label="{{ product.name }} photos">
              <div class="pdp-slider__viewport">
                <div class="pdp-slider__track">
{% for image in product.images %}
                  <img src="{{ image.src }}" alt="{{ image.alt }}" class="pdp-slider__slide" {% if loop.first %}width="{{ image.width }}" height="{{ image.height }}" fetchpriority="high"{% else %}loading="lazy" width="{{ image.width }}" height="{{ image.height }}"{% endif %} />
{% endfor %}
                </div>
              </div>
              <div class="pdp-slider__controls">
                <button type="button" class="pdp-slider__btn pdp-slider__btn--prev" aria-label="Previous photo">&#8249;</button>
                <div class="pdp-slider__dots"></div>
                <button type="button" class="pdp-slider__btn pdp-slider__btn--next" aria-label="Next photo">&#8250;</button>
              </div>
            </div>
{% else %}
            <img src="{{ product.images[0].src }}" alt="{{ product.images[0].alt }}" class="pdp__image" width="{{ product.images[0].width }}" height="{{ product.images[0].height }}" fetchpriority="high" />
{% endif %}
          </div>
          <div class="pdp__info">
            <p class="eyebrow">Handmade in Nicaragua</p>
            <h1 class="pdp__name" id="pdp-heading">{{ product.name }}</h1>
            <p class="pdp__blend">{{ product.blend }}</p>
            <div class="pdp__meta">
              <div class="pdp__price-wrap">
                <span class="pdp__price">{{ product.price }}</span>
                <span class="pdp__count">Bundle of {{ product.quantity }} Cigars</span>
                <span class="pdp__price-note">Plus Tax</span>
              </div>
              <span class="pdp__strength" aria-label="Strength: {{ product.strength }} of 5">
                {%- for i in range(0, 5) %}{% if i < product.strength %}<span class="strength-dot"></span>{% else %}<span class="strength-dot--empty strength-dot"></span>{% endif %}{% endfor %}
                <span class="pdp__strength-label">{{ product.strengthLabel | safe }}</span>
              </span>
            </div>
            <p class="pdp__desc">{{ product.desc | safe }}</p>

            <div class="pdp__specs">
{% for spec in product.specs %}
            <div class="spec">
              <span class="spec__label">{{ spec.label }}</span>
              <span class="spec__value">{{ spec.value | safe }}</span>
            </div>
{% endfor %}
            </div>

            <p class="pdp__notes-heading">Tasting Notes</p>
            <div class="pdp__notes">
{% for note in product.notes %}
            <span class="pdp__note">{{ note }}</span>
{% endfor %}
            </div>

            <div class="pdp__actions">
              <a href="/retailers/" class="btn btn--primary">Find a Retailer</a>
              <a href="/contact/" class="btn btn--ghost">Wholesale Inquiry</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STORY -->
    <section class="section pdp-story" aria-labelledby="story-heading">
      <div class="container">
        <div class="pdp-story__inner">
          <p class="eyebrow">The Blend</p>
          <h2 class="section-heading" id="story-heading">Crafted Leaf by Leaf</h2>
          <div class="gold-rule gold-rule--center" role="presentation"></div>
          <div class="pdp-story__body">
{% for para in product.story %}
            <p>{{ para | safe }}</p>
{% endfor %}
          </div>
        </div>
      </div>
    </section>

    <!-- RELATED -->
    <section class="section related" aria-labelledby="related-heading">
      <div class="container">
        <div class="section-header section-header--centered">
          <p class="eyebrow">The Collection</p>
          <h2 class="section-heading" id="related-heading">Explore More Blends</h2>
        </div>
        <ul class="related__grid" role="list">
{% for relatedSlug in product.related %}
{% for relatedProduct in products %}
{% if relatedProduct.slug == relatedSlug %}
{{ relatedCard(relatedProduct) }}
{% endif %}
{% endfor %}
{% endfor %}
        </ul>
      </div>
    </section>
